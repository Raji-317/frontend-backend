<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>edit the chat</title>
</head>
<body>
    <h3 ><i>Edit the chat:<%= chat._id %></i></h3>
    <p>this chat was sent :<b><%= chat.from %> <b>to  <b> <%=chat.to %></b> </p>
    <form method="POST" action="/chats/<%=chat._id %>?_method=PUT">
        <textarea name="msg" rows="5" cols="15"> <%=chat.msg %></textarea>
    </br>
        <button>edit</button>
    </form>
</body>
</html>