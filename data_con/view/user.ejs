<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>user_page</title>
    <style>
        table,tr,th,td{
            border:1px solid black;
        }
    </style>
</head>
<body>
    <!-- <h3>Displaying the details of users:<%=k%></h3> -->
<table>
    <tr>
        <th>id</th>
        <th>username</th>
        <th>email</th>
        <th>password</th>
    </tr>
    <% for(let user of k){ %>
        <tr>
            <td><%= user.id %></td>
            <td><%= user.username %></td>
            <td><%= user.email %></td>
            <!-- <td><%= user.password %></td> -->
            <td>
            <form method="GET" action="/user/<%= user.id %>/edit">
            <button>Edit Username</button>
          </form>
         </td>
         <td>
            <form method="POST" action="/user/<%= user.id %>?_method=DELETE">
            <button>Delete</button>
            </form>
         </td>
        </tr>
    <% } %>
</table>
</body>
</html>